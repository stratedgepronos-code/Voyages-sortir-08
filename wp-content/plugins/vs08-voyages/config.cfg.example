# Copiez ce fichier en config.cfg et remplissez les clés.
# config.cfg est ignoré par Git (clés secrètes).

# Vols (obligatoire pour les séjours golf)
DUFFEL_API_KEY=duffel_live_XXXXXXXXXXXXXXXX

# Google Flights via SerpApi — EN PRODUCTION : obligatoire si Duffel ne couvre pas l’aéroport (ex. XCR / charters).
# Sur Hostinger : ce fichier doit exister sur le serveur ; il n’est pas poussé par Git (secret).
SERPAPI_API_KEY=votre_cle_serpapi_com

# Recherche IA hôtel & golf (évite "invalid x-api-key")
# Créez une clé sur https://console.anthropic.com/ et vérifiez que le compte a des crédits.
# Par défaut la recherche par nom utilise Haiku (≈3× moins cher) avec cache 48 h.
CLAUDE_API_KEY=sk-ant-api03-xxxx
# Pour forcer Sonnet sur la recherche hôtel (plus précis, plus cher) :
# CLAUDE_MODEL_HOTEL=claude-sonnet-4-20250514

# Paiement Paybox Mail (optionnel)
# PAYBOX_MAIL_APP_KEY=
# PAYBOX_MAIL_SECRET_KEY=

# Tests : déverrouille la dernière étape si token invalide
# VS08_SANDBOX_PAYMENT=0
